{
  "name": "@agenthunter/eval",
  "version": "0.1.0",
  "description": "Open-source AI agent evaluation framework — benchmark MCP servers, A2A agents, and API-first agent services",
  "type": "module",
  "bin": {
    "agent-eval": "./dist/cli.js",
    "agenthunter": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "evaluation",
    "benchmark",
    "mcp",
    "a2a",
    "agent-eval",
    "agenthunter",
    "llm",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OrrisTech/agent-eval"
  },
  "homepage": "https://github.com/OrrisTech/agent-eval",
  "bugs": {
    "url": "https://github.com/OrrisTech/agent-eval/issues"
  },
  "author": "AgentHunter",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "ora": "^9.3.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
